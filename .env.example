# Twilio credentials (https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
PHONE_NUMBER_FROM=+1XXXXXXXXXX

# OpenAI API key with Realtime API access (https://platform.openai.com)
OPENAI_API_KEY=sk-your-openai-api-key

# ngrok domain, no https://
DOMAIN=your-ngrok-domain.ngrok.app

# Server port
PORT=6060

# OpenAI Realtime settings
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_VOICE=shimmer
OPENAI_TEMPERATURE=0.7
OPENAI_WS_OPEN_TIMEOUT=60
OPENAI_WS_MAX_RETRIES=3

# Target test line (do not change)
TARGET_PHONE_NUMBER=+18054398008

# Call settings
MAX_CALL_DURATION_SECONDS=180
CALL_COOLDOWN_SECONDS=30

# Patient TTS is quiet on Twilio dual-channel recordings — boost outbound μ-law (try 3–5)
PATIENT_OUTBOUND_GAIN=4.0
# Don't cut patient audio on brief agent noise until this many ms of patient speech
INTERRUPTION_MIN_MS=800
